APP_NAME="SvoyDom CRM Bot"
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
# Timeweb Cloud Apps may inject PORT automatically; leave APP_PORT as the local/default fallback.
PUBLIC_BASE_URL=https://api.example.com
DATABASE_URL=postgresql+asyncpg://USER:URL_ENCODED_PASSWORD@HOST:5432/DB_NAME?ssl=require
BOT_TOKEN=replace-with-telegram-bot-token
ADMIN_TELEGRAM_IDS=123456789,987654321
CRM_WEBHOOK_TOKEN=replace-with-random-site-webhook-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-telegram-webhook-secret
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://api.example.com/telegram/webhook
LEAD_REMINDER_MINUTES=30
LEAD_REASSIGN_MINUTES=60
CORS_ORIGINS=https://svoydom-lugansk.ru,http://localhost:3000
